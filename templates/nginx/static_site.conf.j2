# Nginx Static Site Configuration (T-071)
# Generated by AXLE OS for static HTML/CSS/JS sites.

server {
    listen 80;
    server_name {{ domain | default('_', true) }};

    root /var/www/{{ app_name }}/{{ static_dir | default('.', true) }};
    index index.html index.htm;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;

    # Logging
    access_log /var/log/nginx/{{ app_name }}_access.log;
    error_log /var/log/nginx/{{ app_name }}_error.log;

    # Cache static assets
    location ~* \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # SPA fallback (for React/Vue/Next.js static exports)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Deny hidden files
    location ~ /\. {
        deny all;
    }
}
